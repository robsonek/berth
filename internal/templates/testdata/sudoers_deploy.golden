# managed by berth
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl reload php8.5-fpm
deploy ALL=(root) NOPASSWD: /usr/bin/supervisorctl reread
deploy ALL=(root) NOPASSWD: /usr/bin/supervisorctl update
deploy ALL=(root) NOPASSWD: /usr/bin/supervisorctl start myapp-worker:*
deploy ALL=(root) NOPASSWD: /usr/bin/supervisorctl stop myapp-worker:*
deploy ALL=(root) NOPASSWD: /usr/bin/supervisorctl restart myapp-worker:*
