# managed by berth
server {
    listen 80;
    server_name app.example.com;

    server_tokens off;

    location /.well-known/acme-challenge/ {
        root /var/www/berth-acme/app.example.com;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    listen 443 quic reuseport;
    listen [::]:443 quic reuseport;
    http2 on;
    http3 on;
    server_name app.example.com;
    root /home/deploy/myapp/current/public;
    index index.php;

    server_tokens off;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Alt-Svc 'h3=":443"; ma=86400' always;
    client_max_body_size 32m;

    ssl_certificate /etc/letsencrypt/live/app.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/app.example.com/privkey.pem;

    location /.well-known/acme-challenge/ {
        root /var/www/berth-acme/app.example.com;
    }

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }

    # Fingerprinted Vite assets: cache for a year and gzip (static only — keeps
    # compression off dynamic responses, avoiding BREACH; no add_header here so
    # the inherited security headers are preserved).
    location ^~ /build/assets/ {
        access_log off;
        expires 1y;
        gzip on;
        gzip_comp_level 5;
        gzip_min_length 256;
        gzip_types text/css text/javascript application/javascript application/json image/svg+xml;
    }

    error_page 404 /index.php;

    location ~ \.php$ {
        fastcgi_pass unix:/run/php/berth-app_example_com.sock;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param HTTPS on;
        fastcgi_hide_header X-Powered-By;
        fastcgi_buffer_size 32k;
        fastcgi_buffers 16 16k;
        fastcgi_busy_buffers_size 32k;
        fastcgi_read_timeout 300;
        fastcgi_send_timeout 300;
    }

    location ~ /\.(?!well-known).* { deny all; }
}
