# managed by berth
webuser ALL=(root) NOPASSWD: /usr/bin/systemctl reload php8.5-fpm
webuser ALL=(root) NOPASSWD: /usr/bin/supervisorctl reread
webuser ALL=(root) NOPASSWD: /usr/bin/supervisorctl update
webuser ALL=(root) NOPASSWD: /usr/bin/supervisorctl start berth-app_example_com\:\*
webuser ALL=(root) NOPASSWD: /usr/bin/supervisorctl stop berth-app_example_com\:\*
webuser ALL=(root) NOPASSWD: /usr/bin/supervisorctl restart berth-app_example_com\:\*
webuser ALL=(root) NOPASSWD: /usr/bin/supervisorctl start berth-app_example_com-reverb\:\*
webuser ALL=(root) NOPASSWD: /usr/bin/supervisorctl stop berth-app_example_com-reverb\:\*
webuser ALL=(root) NOPASSWD: /usr/bin/supervisorctl restart berth-app_example_com-reverb\:\*
