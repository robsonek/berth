; managed by berth
[myapp]
user = deploy
group = deploy

listen = /run/php/php8.5-fpm.sock
listen.owner = www-data
listen.group = www-data
listen.mode = 0660

pm = dynamic
pm.max_children = 10
pm.start_servers = 2
pm.min_spare_servers = 1
pm.max_spare_servers = 4

php_admin_value[error_log] = /var/log/php/myapp-fpm.error.log
php_admin_flag[log_errors] = on
