; managed by berth
[app_example_com]
user = webuser
group = webuser

listen = /run/php/berth-app_example_com.sock
listen.owner = www-data
listen.group = www-data
listen.mode = 0660

pm = dynamic
pm.max_children = 10
pm.start_servers = 2
pm.min_spare_servers = 1
pm.max_spare_servers = 4

php_admin_value[open_basedir] = /home/deploy/myapp/current:/home/deploy/myapp/shared:/tmp
php_admin_value[error_log] = /var/log/php/app_example_com-fpm.error.log
php_admin_flag[log_errors] = on
